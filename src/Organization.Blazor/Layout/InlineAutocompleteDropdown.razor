@typeparam TItem

<div class="position-relative">
    <input id="@Id"
           class="form-control"
           value="@Value"
           placeholder="@Placeholder"
           disabled="@Disabled"
           @onfocus="OpenDropdown"
           @oninput="OnInputChanged"
           @onblur="CloseDropdown" />

    @if (!Disabled && IsDropdownOpen && FilteredItems.Count > 0)
    {
        <div class="position-absolute w-100 border rounded bg-white mt-1 shadow-sm" style="z-index: 1050; max-height: 220px; overflow-y: auto;">
            @foreach (var item in FilteredItems)
            {
                var displayText = GetItemText(item);
                <button type="button"
                        class="btn btn-link text-start w-100 text-decoration-none"
                        @onmousedown="() => SelectItem(displayText)">
                    @displayText
                </button>
            }
        </div>
    }
</div>
