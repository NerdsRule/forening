
<div class="card mt-4">
    <div class="card-header">

        <span class="card-title fs-6 d-block d-md-none fw-bold">Task List for @StaticUserInfoBlazor.SelectedDepartment?.Department?.Name <button class="btn btn-sm btn-primary ms-4 oi oi-reload" @onclick="RefreshTasks" title="Refresh the list"></button></span>
        <span class="card-title fs-4 d-none d-md-block fw-bold">Task List for @StaticUserInfoBlazor.SelectedDepartment?.Department?.Name <button class="btn btn-sm btn-primary ms-4 oi oi-reload" @onclick="RefreshTasks" title="Refresh the list"></button></span>
        
        
    </div>
    <div class="card-body">
        @if (_tasks.Any())
        {
            <div class="d-none d-sm-block">
                <div class="row">
                    <div class="col-12 col-md-1">
                        <strong>Date</strong>
                    </div>
                    <div class="col-12 col-md-2">
                        <strong>Department</strong>
                    </div>
                    <div class="col-12 col-md-3">
                        <strong>Name</strong>
                    </div>
                    <div class="col-12 col-md-1">
                        <strong>Points</strong>
                    </div>
                    <div class="col-12 col-md-1">
                        <strong>Status</strong>
                    </div>
                    <div class="col-12 col-md-3">
                        <strong>Assigned</strong>
                    </div>
                    <div class="col-12 col-md-1">
                        <strong>Details</strong>
                    </div>
                </div>
            </div>
            @foreach (var task in _sortedAndFilteredTasks)
            {
                <DepartmentTaskComponent @ref="_taskComponents[task.Id]" ChildContent="task" InitDisplayDetails="false" OnTaskDeletedEvent="RemoveTaskFromList" UsersWithAccess="UsersWithAccess" />
            }
        }
        <FormResultComponent @ref="_taskResult" />
    </div>
</div>


