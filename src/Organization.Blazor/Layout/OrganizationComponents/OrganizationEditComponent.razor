	
    <div class="card mt-2">
        <div class="card-header">
            <span class="fs-4 fw-bold me-4">Organizations</span>
            <SpinnerComponent ShowSpinner="_showSpinner" />
        </div>
        <div class="card-body">
	<FormResultComponent @ref="_formResult" />
	
	<div class="row border border-secondary rounded rounded-1 my-2 p-3">
		<div class="col-12">
			

			<EditForm Model="_organization" OnValidSubmit="HandleAddUpdateAsync">
				<DataAnnotationsValidator />
				<ValidationSummary />

				<div class="row g-3">
					<div class="col-12 col-md-6">
						<label class="form-label">Name</label>
						<InputText class="form-control" @bind-Value="_organization.Name" />
						<ValidationMessage For="() => _organization.Name" />
					</div>
					<div class="col-12 col-md-6">
						<label class="form-label">Address</label>
						<InputText class="form-control" @bind-Value="_organization.Address" />
						<ValidationMessage For="() => _organization.Address" />
					</div>
					<div class="col-12 col-md-6">
						<label class="form-label">Contact Email</label>
						<InputText class="form-control" @bind-Value="_organization.ContactEmail" />
						<ValidationMessage For="() => _organization.ContactEmail" />
					</div>
					<div class="col-12 col-md-6">
						<label class="form-label">Contact Phone</label>
						<InputText class="form-control" @bind-Value="_organization.ContactPhone" />
						<ValidationMessage For="() => _organization.ContactPhone" />
					</div>
					<div class="col-12">
						<div class="form-check">
							<InputCheckbox class="form-check-input" @bind-Value="_organization.IsActive" />
							<label class="form-check-label">Active</label>
						</div>
					</div>
				</div>

				<div class="row mt-3">
					<div class="col-auto">
						<button type="submit" class="btn btn-primary">@AddUpdateText Organization</button>
					</div>
					<div class="col-auto">
						<button type="button" class="btn btn-secondary" @onclick="NewOrganization">Clear</button>
					</div>
				</div>
			</EditForm>
		</div>
	</div>

	@if (_organizations.Any())
	{
		@foreach (var organization in _organizations.OrderBy(o => o.Name))
		{
			<div class="row border border-1 border-secondary rounded rounded-1 mt-2 p-2 align-items-center">
				<div class="col-12 col-md-4">
					<strong>@organization.Name</strong>
				</div>
				<div class="col-12 col-md-3">
					@organization.ContactEmail
				</div>
				<div class="col-12 col-md-2">
					@(organization.IsActive ? "Active" : "Inactive")
				</div>
				<div class="col-12 col-md-3 text-md-end">
					<button type="button" class="btn btn-sm btn-outline-primary me-2" @onclick="() => EditOrganization(organization)">Edit</button>
					<button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => DeleteOrganizationAsync(organization.Id)">Delete</button>
				</div>
			</div>
		}
	}
	else
	{
		<div class="alert alert-info mt-3">No organizations found.</div>
	}
    </div>
    </div>
    @if (_selectedOrganizationId > 0)
	{
		<DepartmentEditComponent OrganizationId="_selectedOrganizationId" OnDepartmentAdded="HandleDepartmentAddedAsync" />
	}
