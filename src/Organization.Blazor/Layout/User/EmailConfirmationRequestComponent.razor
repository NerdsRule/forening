@if (StaticUserInfoBlazor.User is not null && !StaticUserInfoBlazor.User.EmailConfirmed)
{
    <div class="card mt-2">
        <div class="card-header">
            <span class="fs-6 d-block d-md-none fw-bold">Confirm Your Email</span>
            <span class="fs-4 d-none d-md-block fw-bold">Confirm Your Email</span>
        </div>
        <div class="card-body">
            <p class="card-text">
                Your email address is not confirmed yet.<br>
                Note that we only user your mail address to send you important information about your account and our service. We will never send you marketing emails or share your email with third parties.<br>
                Click the button below and we will send a confirmation email to your registered address.
            </p>

            <button type="button" class="btn btn-primary" @onclick="HandleRequestEmailConfirmationAsync" disabled="@isBusy">
                Send Confirmation Email
            </button>

            <FormResultComponent @ref="FormResult" />
        </div>
    </div>
}