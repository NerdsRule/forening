<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                @if (HasResetToken)
                {
                    <span class="fs-6 d-block d-md-none fw-bold">Reset Password</span>
                    <span class="fs-4 d-none d-md-block fw-bold">Reset Password</span>
                }
                else
                {
                    <span class="fs-6 d-block d-md-none fw-bold">Request Password Reset</span>
                    <span class="fs-4 d-none d-md-block fw-bold">Request Password Reset</span>
                }
            </div>
            <div class="card-body">
                @if (!string.IsNullOrWhiteSpace(InfoText))
                {
                    <div class="alert alert-info" role="alert">@InfoText</div>
                }

                @if (ShowInvalidLinkMessage)
                {
                    <div class="alert alert-danger" role="alert">
                        The reset link is invalid. Request a new password reset link.
                    </div>
                }
                else if (HasResetToken)
                {
                    <EditForm Model="ResetModel" OnValidSubmit="HandleResetOwnPasswordAsync">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="mb-3">
                            <label for="newPassword" class="form-label">New Password</label>
                            <InputText id="newPassword" type="password" class="form-control" @bind-Value="ResetModel.Password" />
                            <ValidationMessage For="@(() => ResetModel.Password)" />
                        </div>

                        <div class="mb-3">
                            <label for="confirmPassword" class="form-label">Confirm Password</label>
                            <InputText id="confirmPassword" type="password" class="form-control" @bind-Value="ResetModel.ConfirmPassword" />
                            <ValidationMessage For="@(() => ResetModel.ConfirmPassword)" />
                        </div>

                        <button type="submit" class="btn btn-primary me-3" disabled="@isBusy">Reset Password</button>
                        <a class="btn btn-link px-0" href="/reset-my-password">Request a new link</a>
                    </EditForm>
                }
                else
                {
                    <EditForm Model="RequestModel" OnValidSubmit="HandleRequestPasswordResetAsync">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="mb-3">
                            <label for="email" class="form-label">Email</label>
                            <InputText id="email" class="form-control" @bind-Value="RequestModel.Email" />
                            <ValidationMessage For="@(() => RequestModel.Email)" />
                        </div>

                        <button type="submit" class="btn btn-primary me-3" disabled="@isBusy">Send Reset Link</button>
                        <a class="btn btn-link px-0" href="/">Back to login</a>
                    </EditForm>
                }

                <FormResultComponent @ref="FormResult" />
            </div>
        </div>
    </div>
</div>