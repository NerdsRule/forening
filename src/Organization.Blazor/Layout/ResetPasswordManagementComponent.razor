<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span class="fs-6 d-block d-md-none fw-bold">Reset Password Requests</span>
        <span class="fs-4 d-none d-md-block fw-bold">Reset Password Requests</span>
        <button class="btn btn-outline-secondary btn-sm" @onclick="LoadAsync" disabled="@_isBusy">Refresh</button>
    </div>
    <div class="card-body">
        <FormResultComponent @ref="_formResult" />

        <SpinnerComponent ShowSpinner="_isBusy" />
        
        @if (_resetRequests.Count == 0)
        {
            <p class="mb-0">No reset requests found.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Id</th>
                            <th>User Id</th>
                            <th>Request Count</th>
                            <th>Last Requested</th>
                            <th>Blocked</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in _resetRequests.OrderByDescending(r => r.LastResetRequestAt))
                        {
                            <tr>
                                <td>@row.Id</td>
                                <td>@row.AppUserId</td>
                                <td>@row.ResetRequestCount</td>
                                <td>@(row.LastResetRequestAt?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                                <td>@(row.IsResetMailBlocked ? "Yes" : "No")</td>
                                <td class="text-end">
                                    <button class="btn btn-danger btn-sm" @onclick="() => DeleteAsync(row.Id)" disabled="@_isBusy">Delete</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>