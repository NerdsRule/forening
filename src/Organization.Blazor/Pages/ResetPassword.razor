@page "/reset-password"
@attribute [Authorize(Roles = "OrganizationAdmin,EnterpriseAdmin")]

<PageTitle>Reset Password</PageTitle>

<div class="container-fluid mt-4">
    <div class="card">
        <div class="card-header">
            <span class="fs-6 d-block d-md-none fw-bold">Reset Password</span>
            <span class="fs-3 d-none d-md-block fw-bold">Reset Password</span>
        </div>
                <div class="card-body">
                    @if (_users != null)
                    {
                        <div class="mb-3">
                            <label class="form-label">Select User</label>
                            <InlineAutocompleteDropdown TItem="UserModel"
                                                        Id="resetPasswordUserDropdown"
                                                        Items="_users.OrderByDescending(c => c.DisplayName).ToList()"
                                                        ItemTextSelector="GetUserDisplayText"
                                                        Value="@_userSearchText"
                                                        ValueChanged="OnUserSearchChanged"
                                                        OnItemSelected="OnUserSelectedFromTypeAhead"
                                                        Placeholder="Type user name or username..." 
                                                        MaxSuggestions="100"/>
                        </div>
                    }
                    @if (_selectedUser != null)
                    {
                        <EditForm Model="@_resetPasswordModel" OnValidSubmit="HandleValidSubmit">
                            <DataAnnotationsValidator />
                            <ValidationSummary />

                            <div class="mb-3">
                                <label for="newPassword" class="form-label">New Password</label>
                                <InputText id="newPassword" type="password" class="form-control" @bind-Value="_resetPasswordModel.Password" />
                                <ValidationMessage For="@(() => _resetPasswordModel.Password)" />
                            </div>
                            <div class="mb-3">
                                <label for="confirmPassword" class="form-label">Confirm Password</label>
                                <InputText id="confirmPassword" type="password" class="form-control" @bind-Value="_resetPasswordModel.ConfirmPassword" />
                                <ValidationMessage For="@(() => _resetPasswordModel.ConfirmPassword)" />
                            </div>
                            <button type="submit" class="btn btn-primary">Reset Password</button>
                        </EditForm>
                    }
                    <FormResultComponent @ref="FormResult" />
                </div>
            </div>
</div>